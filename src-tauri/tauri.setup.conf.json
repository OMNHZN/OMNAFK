{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OMNAFK Setup",
  "version": "0.1.19",
  "identifier": "io.omnafk.setup",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}

